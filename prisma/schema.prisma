//prisma/schema.prisma
//DATABASE SCHEMA — Car Rental Booking System
//This file has all database tables and relationships.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  //Using PostgreSQL as the database provider
  provider = "sqlite"
  //url      = env("DATABASE_URL")
}


//ENUMS

//regular users and admins
enum Role {
  USER
  ADMIN
}

//Booking status lifecycle
enum BookingStatus {
  PENDING    //Newly created, waiting for admin action
  CONFIRMED  //Admin approved
  DECLINED   //Admin rejected
  CANCELLED  //User cancelled
}


//USERS TABLE
model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String    // Hashed with bcrypt 
  firstName String
  lastName  String
  phone     String?   
  role      Role      @default(USER) //Default role is regular user
  bookings  Booking[] //A user can have more then one booking

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users") //Table name in database
}

// ─────────────────────────────────────────────
// CARS TABLE
// ─────────────────────────────────────────────
model Car {
  id           String    @id @default(uuid())
  make         String    
  model        String    
  year         Int       
  category     String    //economy, sedan, suv, luxury, van
  pricePerDay  Float     //Rental cost per day in CAD
  seats        Int       //Number of passenger seats
  transmission String    //automatic or manual
  fuelType     String    //gasoline, diesel, electric, hybrid
  imageUrl     String?   //Optional URL for car photo
  available    Boolean   @default(true) //Is car avibale for rentingh?
  bookings     Booking[] //Car can also have more then one bookings

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cars")
}


//BOOKINGS TABLE

model Booking {
  id String @id @default(uuid())

  //Car being booked (required)
  car   Car    @relation(fields: [carId], references: [id])
  carId String

  //Registered user
  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  //Guest information 
  guestName  String?
  guestEmail String?
  guestPhone String?
  isGuest    Boolean @default(false) // True if booked without account

  //Booking period
  startDate DateTime
  endDate   DateTime

  //Financial
  totalPrice Float //Calculated: pricePerDay × number of days rented

  //Status managed by admin
  status BookingStatus @default(PENDING)

  //Optional customer notes
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bookings")
}